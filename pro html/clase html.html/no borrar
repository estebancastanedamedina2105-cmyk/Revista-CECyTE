<!DOCTYPE html>
<html>
  <head>
    <title>Calendario por mes</title>
    <style>
      table {
        border-collapse: collapse;
        margin-top: 20px;
      }
      th,
      td {
        border: 1px solid black;
        width: 40px;
        height: 40px;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <label>Selecciona un mes:</label>
    <input type="month" id="mes" />

    <div id="calendario"></div>

    <script>
      document.getElementById("mes").addEventListener("change", function () {
        const valor = this.value; // formato: 2026-03
        const [año, mes] = valor.split("-");

        generarCalendario(parseInt(año), parseInt(mes));
      });

      function generarCalendario(año, mes) {
        const calendario = document.getElementById("calendario");
        calendario.innerHTML = "";

        const fecha = new Date(año, mes - 1, 1);
        const ultimoDia = new Date(año, mes, 0).getDate();
        const primerDiaSemana = fecha.getDay();

        let tabla = "<table>";
        tabla +=
          "<tr><th>Dom</th><th>Lun</th><th>Mar</th><th>Mié</th><th>Jue</th><th>Vie</th><th>Sáb</th></tr>";
        tabla += "<tr>";

        for (let i = 0; i < primerDiaSemana; i++) {
          tabla += "<td></td>";
        }

        for (let dia = 1; dia <= ultimoDia; dia++) {
          if ((primerDiaSemana + dia - 1) % 7 === 0) {
            tabla += "</tr><tr>";
          }
          tabla += "<td>" + dia + "</td>";
        }

        tabla += "</tr></table>";
        calendario.innerHTML = tabla;
      }
    </script>
  </body>
</html>
